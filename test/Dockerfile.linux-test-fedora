FROM fedora:40

# Inject CA certificates BEFORE dnf — Fedora base ships update-ca-trust,
# and any SSL-inspecting proxy must be trusted before package downloads.
COPY certificates/ /tmp/certs/
RUN for cert in /tmp/certs/*.pem /tmp/certs/*.crt; do \
      [ -f "$cert" ] || continue; \
      cp "$cert" /etc/pki/ca-trust/source/anchors/; \
    done && update-ca-trust extract

RUN dnf install -y sudo curl ca-certificates && \
    dnf clean all

RUN useradd -m -s /bin/bash fledger && \
    echo "fledger ALL=(ALL) NOPASSWD: ALL" >> /etc/sudoers

USER fledger
WORKDIR /home/fledger

CMD ["/bin/bash"]
