FROM archlinux:latest

# Must happen before package downloads — an untrusted proxy CA will cause pacman to fail.
COPY certificates/ /tmp/certs/
RUN for cert in /tmp/certs/*.pem /tmp/certs/*.crt; do \
      [ -f "$cert" ] || continue; \
      cp "$cert" /etc/ca-certificates/trust-source/anchors/; \
    done && trust extract-compat

# pacman's seccomp sandbox fails under QEMU x86_64 emulation on Apple Silicon
RUN echo "DisableSandbox" >> /etc/pacman.conf && \
    pacman -Sy --noconfirm sudo curl ca-certificates && \
    pacman -Sc --noconfirm

RUN useradd -m -s /bin/bash fledger && \
    echo "fledger ALL=(ALL) NOPASSWD: ALL" >> /etc/sudoers

USER fledger
WORKDIR /home/fledger

CMD ["/bin/bash"]
