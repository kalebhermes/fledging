# Test environment for linux-install.sh on Alpine Linux (apk)
# Alpine APK uses HTTP repos by default so Zscaler CA injection can happen after initial install.
# bash must be installed — Alpine ships sh only.
FROM alpine:3.21

RUN apk add --no-cache sudo bash curl ca-certificates

# Inject Zscaler CA after ca-certificates is installed
COPY zscaler-ca.pem /usr/local/share/ca-certificates/zscaler.crt
RUN update-ca-certificates

RUN adduser -D -s /bin/bash fledger && \
    echo "fledger ALL=(ALL) NOPASSWD: ALL" >> /etc/sudoers

USER fledger
WORKDIR /home/fledger

CMD ["/bin/bash"]
